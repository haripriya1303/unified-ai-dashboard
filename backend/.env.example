# Copy to .env and fill in values

# Database (local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/unified_ai_dashboard

# Supabase (for JWT verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# Optional: bypass auth in local dev (set to true to skip JWT verification)
DEV_AUTH_BYPASS=false

# Redis (local)
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible LLM API (e.g. OpenAI, local Ollama)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_MODEL=gpt-4o-mini

# Embeddings (can use same or different model)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Webhook secrets (per integration)
SLACK_SIGNING_SECRET=
GITHUB_WEBHOOK_SECRET=
JIRA_WEBHOOK_SECRET=
NOTION_WEBHOOK_SECRET=
